# ── Clerk (authentication) ───────────────────────────────────────────────────
# From Clerk Dashboard → API Keys (or written by `clerk init`)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# ── Supabase (database only — not used for Auth) ─────────────────────────────
# Project URL + keys: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Telegram ──────────────────────────────────────────────────────────────────
# One shared bot for the whole app — create it once with @BotFather.
# Each user links their own chat from the app (Settings → Connect Telegram).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Optional: a chat id that receives scrape progress/status messages
TELEGRAM_ADMIN_CHAT_ID=
# Random secret (e.g. openssl rand -hex 32) — sent as Telegram secret_token
TELEGRAM_WEBHOOK_SECRET=
# Protects one-time webhook registration: /api/telegram-webhook/register?secret=...
ADMIN_SETUP_SECRET=

# ── App URL (SEO / absolute links; optional on Vercel) ────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Analytics ────────────────────────────────────────────────────────────────
# Vercel Analytics + Speed Insights: enable in Vercel project (no keys required)
# PostHog: https://app.posthog.com → Project Settings → Project API Key
# Either name works (PROJECT_TOKEN is PostHog's newer label)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Use https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU)
# Or set to /ingest to use the same-origin reverse proxy in next.config.ts
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── GitHub (powers the "Run Now" button) ─────────────────────────────────────
# Personal access token with `workflow` scope
GITHUB_PAT=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=master
